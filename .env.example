# Guide Builder — optional "Submit for approval" wiring.
#
# Copy this file to ".env.local" (git-ignored) and fill in a value, OR set the
# variable in your Vercel project settings. With neither set, the Submit button
# just shows an honest "not connected" message and you rely on Copy/Download.

# Web3Forms (recommended). Get a free access key at https://web3forms.com by
# entering the email you want submissions sent to. This key is PUBLIC by design
# (spam protected) — it is safe to expose in the frontend bundle.
VITE_WEB3FORMS_ACCESS_KEY=

# Alternative: any custom form-to-email relay endpoint that accepts a JSON POST
# of the draft. Leave blank if you are using Web3Forms above.
VITE_COURSE_SUBMISSION_ENDPOINT=
